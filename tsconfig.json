{
    "compilerOptions": {
        "esModuleInterop": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2020",
        "lib": ["ESNext", "DOM"],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"],
    "tsc-alias": {
        "resolveFullPaths": true,
        "verbose": false
    }
}
